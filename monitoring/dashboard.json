{
  "title": "Pay — 결제 시스템",
  "schemaVersion": 39,
  "panels": [
    {
      "title": "결제 성공률 (SLO)",
      "type": "stat",
      "targets": [{
        "expr": "sum(rate(payment_confirm_total{outcome=\"success\"}[5m])) / sum(rate(payment_confirm_total[5m]))"
      }]
    },
    {
      "title": "결제 승인 결과 (결과별)",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (outcome) (rate(payment_confirm_total[1m]))" }]
    },
    {
      "title": "요청 p99 레이턴시",
      "type": "timeseries",
      "targets": [{
        "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))"
      }]
    },
    {
      "title": "HikariCP 커넥션 사용",
      "type": "timeseries",
      "targets": [{ "expr": "hikaricp_connections_active" }, { "expr": "hikaricp_connections_max" }]
    },
    {
      "title": "서킷브레이커 상태",
      "type": "timeseries",
      "targets": [{ "expr": "resilience4j_circuitbreaker_state" }]
    }
  ]
}
